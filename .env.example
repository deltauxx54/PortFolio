# ── Frontend API Base ──────────────────────────────────
# URL de base du backend Laravel (sans slash final)
# Exemple: http://127.0.0.1:8001/api
VITE_API_BASE=http://127.0.0.1:8001/api

# ── Port du serveur Express/Vite ───────────────────────
PORT=3001

# ── Email (formulaire de contact) ─────────────────────
# Service SMTP: gmail | outlook | yahoo | etc.
EMAIL_SERVICE=gmail

# Votre adresse email (expéditeur)
EMAIL_USER=votre.email@gmail.com

# Mot de passe d'application Gmail
# (Activez la validation en 2 étapes puis créez un mot de passe d'application)
# https://myaccount.google.com/apppasswords
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# Email de destination des messages reçus (par défaut = EMAIL_USER)
EMAIL_TO=votre.email@gmail.com
